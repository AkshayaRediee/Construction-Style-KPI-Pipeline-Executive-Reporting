{
  "datasets": [
    {
      "name": "87975129",
      "displayName": "Portofolio Summary",
      "queryLines": [
        "SELECT\r\n",
        "  SUM(baseline_budget) AS total_baseline_budget,\r\n",
        "  SUM(total_actual_cost) AS total_actual_cost,\r\n",
        "  SUM(total_forecast_budget) AS total_forecast_budget,\r\n",
        "  SUM(cost_variance_amount) AS total_cost_variance_amount\r\n",
        "FROM construction_kpi.gold_project_kpis;"
      ]
    },
    {
      "name": "ebccff55",
      "displayName": "Risk Status Count",
      "queryLines": [
        "SELECT\r\n",
        "  risk_status,\r\n",
        "  COUNT(*) AS project_count\r\n",
        "FROM construction_kpi.gold_project_kpis\r\n",
        "GROUP BY risk_status\r\n",
        "ORDER BY project_count DESC;"
      ]
    },
    {
      "name": "da9152ea",
      "displayName": "Top Overrun Projects",
      "queryLines": [
        "SELECT\r\n",
        "  project_id,\r\n",
        "  project_name,\r\n",
        "  client_name,\r\n",
        "  cost_variance_amount,\r\n",
        "  cost_variance_pct,\r\n",
        "  latest_delay_days,\r\n",
        "  risk_status\r\n",
        "FROM construction_kpi.gold_project_kpis\r\n",
        "ORDER BY cost_variance_pct DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "e157c0bb",
      "displayName": "Delay vs Cost Variance",
      "queryLines": [
        "SELECT\r\n",
        "  project_id,\r\n",
        "  project_name,\r\n",
        "  latest_delay_days,\r\n",
        "  cost_variance_pct,\r\n",
        "  risk_status\r\n",
        "FROM construction_kpi.gold_project_kpis;"
      ]
    },
    {
      "name": "3f538d6a",
      "displayName": "Portofolio Breakdown by Region",
      "queryLines": [
        "SELECT\r\n",
        "  region,\r\n",
        "  COUNT(*) AS project_count,\r\n",
        "  SUM(total_forecast_budget) AS forecast_budget,\r\n",
        "  AVG(cost_variance_pct) AS avg_cost_variance_pct,\r\n",
        "  AVG(latest_delay_days) AS avg_delay_days\r\n",
        "FROM construction_kpi.gold_project_kpis\r\n",
        "GROUP BY region\r\n",
        "ORDER BY forecast_budget DESC;"
      ]
    }
  ],
